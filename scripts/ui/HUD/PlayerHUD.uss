.hud-main-container {
    width: 450px;
    height: 250px;
    flex-direction: row;
    padding: 15px;
    margin-bottom: 20px;
    margin-left: 20px;
    background-color: rgba(0, 0, 0, 0);
    border-radius: 10px;
    align-items: center;
    position: absolute;
    bottom: 40px;
    left: 40px;
}

.portrait-style {
    width: 150px;
    height: 150px;
    background-color: rgb(68, 68, 68);
    border-width: 4px;
    border-color: black;
    border-radius: 5px;
}

.info-layout {
    flex-direction: column;
    margin-left: 15px;
    justify-content: center;
}

.text-row {
    flex-direction: row;
    margin-bottom: 10px;
}

.hp-text {
    color: white;
    font-size: 24px;
    -unity-font-style: bold;
    padding-right: 100px;
}

.shield-text {
    color: white;
    font-size: 18px;
    -unity-font-style: bold;
}

.bar-bg {
    width: 400px;
    height: 50px;
    background-color: rgb(50, 50, 50);
    border-radius: 4px;
    border-width: 4px;
    border-color: black;
    overflow: hidden;
    position: relative;
    margin-top : 20px;
}

.hp-fill {
    height: 100%;
    background-color: rgb(231, 76, 60);
    width: 100%;
    position: absolute;
    left: 0;
    top: 0;
}

.shield-fill {
    height: 100%; /* УМЗТ ЙйПЭ ЕПРЯЧб БНБт */
    /* ПЁГЪСі НЏЕх ДРГІРЧ ХѕИэЧб ЧЯДУЛі МГСЄ */
    background-color: rgba(52, 152, 219, 0.5); 
    
    width: 100%; /* УЪБтАЊ, НКХЉИГЦЎПЁМ­ СЖР§ЕЪ */
    position: absolute; /* Р§Ды СТЧЅ МГСЄ */
    left: 0;
    top: 0;
    
    /* НУАЂРћ ФїИЎЦМ Ої: ОрАЃРЧ ЙпБЄ ШПАњ(Neon)ИІ РЇЧб БзИВРк */
    -unity-text-outline-color: rgba(129, 236, 236, 0.3);
    -unity-text-outline-width: 1px;
}

.xp-container {
    position: absolute;
    top: 20px;
    left: 5%;
    right: 5%;
    height: 30px;
    flex-direction: column;
    align-items: center;
}

.xp-bar-bg {
    width: 100%;
    height: 15px;
    background-color: rgba(0, 0, 0, 0.1);
    border-radius: 7px;
    border-width: 2px;
    border-color: black;
    overflow: hidden;
    align-items: flex-start;
    justify-content: flex-start;
    flex-direction: row;
}

.xp-fill {
    height: 100%;
    background-color: rgb(0, 255, 0);
    width: 0%;
    margin-left: 0;
    margin-right: auto;
}

.xp-text {
    color: white;
    font-size: 32px;
    -unity-font-style: bold;
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: black;
    margin-top: 5px;
}

.gold-container {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    padding: 5px 20px;
    background-color: rgba(0, 0, 0, 0);
    position: absolute;
    top: 80px;
    left: 5%;
    right: 5%;
    height: 40px;
}

.hud-info-group {
    flex-direction: row;
    align-items: center;
}

.gold-icon {
    width: 24px;
    height: 24px;
    background-color: rgb(255, 215, 0);
    margin-right: 8px;
    border-radius: 12px;
    border-width: 2px;
    border-color: black;
}

.gold-text {
    color: white;
    font-size: 22px;
    -unity-font-style: bold;
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: black;
}

.time-text {
    color: white;
    font-size: 28px;
    -unity-font-style: bold;
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: black;
    margin-left:1200px;
}

.kill-text {
    color: white;
    font-size: 22px;
    -unity-font-style: bold;
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: black;
    margin-left: 1200px;
}
